# Deployer private key (0x-prefixed). Fund this wallet for gas on Base/Base Sepolia.
DEPLOYER_PRIVATE_KEY=

# Challenger private key (0x-prefixed). Fund this wallet if you will challenge on live networks.
CHALLENGER_PRIVATE_KEY=

# Optional custom RPC URLs (defaults are public Base endpoints)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Interactive rollup deployment defaults
CHALLENGE_PERIOD_SECONDS=180
SEQUENCER_BOND_ETH=0.01
CHALLENGER_BOND_ETH=0.005
